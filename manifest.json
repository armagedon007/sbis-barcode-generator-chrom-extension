{
  "manifest_version": 3,
  "name": "СБИС Barcode Generator",
  "version": "1.1.0",
  "description": "Генератор штрихкодов EAN-13 для СБИС",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.sbis.ru/*",
    "https://*.saby.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.sbis.ru/*",
        "https://*.saby.ru/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://*.sbis.ru/*", "https://*.saby.ru/*"]
    }
  ]
}
